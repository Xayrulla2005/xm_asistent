{
  "name": "@org/source",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "api:build": "webpack-cli build --config apps/api/webpack.standalone.js --mode development",
    "api:build:watch": "webpack-cli build --config apps/api/webpack.standalone.js --mode development --watch",
    "api:start": "node apps/api/dist/main.js",
    "api:start:watch": "node --watch apps/api/dist/main.js",
    "migration:run": "node_modules/.bin/typeorm-ts-node-commonjs migration:run -d apps/api/src/data-source.ts",
    "migration:revert": "node_modules/.bin/typeorm-ts-node-commonjs migration:revert -d apps/api/src/data-source.ts",
    "migration:generate": "node_modules/.bin/typeorm-ts-node-commonjs migration:generate -d apps/api/src/data-source.ts",
    "migration:create": "node_modules/.bin/typeorm-ts-node-commonjs migration:create",
    "migration:show": "node_modules/.bin/typeorm-ts-node-commonjs migration:show -d apps/api/src/data-source.ts",
    "test:api": "jest --config apps/api/jest.config.js --passWithNoTests",
    "test:api:watch": "jest --config apps/api/jest.config.js --watch",
    "test:api:coverage": "jest --config apps/api/jest.config.js --coverage"
  },
  "private": true,
  "devDependencies": {
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@nx/js": "22.7.0",
    "@nx/nest": "^22.7.0",
    "@nx/node": "22.7.0",
    "@nx/react": "^22.7.0",
    "@nx/vite": "22.7.0",
    "@nx/web": "22.7.0",
    "@nx/webpack": "22.7.0",
    "@swc-node/register": "1.11.1",
    "@swc/core": "1.15.8",
    "@swc/helpers": "0.5.18",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "20.19.9",
    "@types/passport-jwt": "^4.0.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^6.0.0",
    "@vitest/ui": "~4.1.0",
    "jiti": "2.4.2",
    "jsdom": "~22.1.0",
    "nx": "22.7.0",
    "prettier": "^3.8.1",
    "tslib": "^2.3.0",
    "typescript": "~5.9.2",
    "vite": "^8.0.0",
    "vitest": "~4.1.0",
    "webpack-cli": "^5.1.4"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/throttler": "^6.5.0",
    "@react-oauth/google": "^0.13.5",
    "@types/nodemailer": "^8.0.1",
    "@types/react-router-dom": "^5.3.3",
    "axios": "^1.6.0",
    "bcryptjs": "^2.4.3",
    "exceljs": "^4.4.0",
    "google-auth-library": "^10.7.0",
    "helmet": "^8.3.0",
    "ioredis": "^5.11.1",
    "lucide-react": "^1.18.0",
    "nodemailer": "^8.0.11",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "6.30.3",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.0",
    "zustand": "^5.0.13"
  }
}
